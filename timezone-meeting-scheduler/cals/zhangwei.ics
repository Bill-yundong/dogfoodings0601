DTEND;TZID=Asia/Shanghai:20260622T103000
RRULE:FREQ=DAILY;INTERVAL=1;BYDAY=MO,TU,WE,TH,FR
END:VEVENT
BEGIN:VEVENT
UID:zhangwei-teamreview@example.com
SUMMARY:团队评审会
DTSTART;TZID=Asia/Shanghai:20260624T140000
DTEND;TZID=Asia/Shanghai:20260624T160000
END:VEVENT
BEGIN:VEVENT
UID:zhangwei-lunch@example.com
SUMMARY:午餐
DTSTART;TZID=Asia/Shanghai:20260622T120000
DTEND;TZID=Asia/Shanghai:20260622T130000
RRULE:FREQ=DAILY;INTERVAL=1;BYDAY=MO,TU,WE,TH,FR
END:VEVENT
