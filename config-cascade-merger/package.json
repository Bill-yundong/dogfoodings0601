{
  "name": "config-cascade-merger",
  "version": "1.0.0",
  "description": "多层配置级联合并与校验 CLI 工具",
  "main": "dist/config-cli.js",
  "scripts": {
    "build": "tsc",
    "start": "ts-node config-cli.ts",
    "example": "ts-node config-cli.ts --defaults defaults.yaml --env .env --args '--port 3000 --debug'"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "dotenv": "^16.3.1",
    "js-yaml": "^4.1.0",
    "minimist": "^1.2.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/minimist": "^1.2.2",
    "@types/node": "^20.4.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
