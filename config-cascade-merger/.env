# 环境变量层配置（优先级 3/4，高于 YAML，低于 CLI 参数）
# 规则：使用 APP_ 前缀，双下划线 __ 表示嵌套层级，snake_case 自动转为 camelCase

APP_PORT=9090
APP_DEBUG=true
APP_LOG_LEVEL=debug

# 嵌套对象使用双下划线分隔
APP_DATABASE__HOST=env-db.example.com
APP_DATABASE__PORT=3306
APP_DATABASE__NAME=env_overridden_db
APP_DATABASE__USERNAME=env_user
APP_DATABASE__PASSWORD=EnvSecurePass123!

# 深度嵌套示例：database.pool.min
APP_DATABASE__POOL__MIN=10
APP_DATABASE__POOL__MAX=100

# 功能开关（布尔类型转换）
APP_FEATURES__AUTH=true
APP_FEATURES__CACHE=false
APP_FEATURES__RATE_LIMIT=true

# 数组类型（逗号分隔，会按 schema 转换为字符串数组）
APP_ALLOWED_ORIGINS=https://env1.example.com,https://env2.example.com

# 限流参数（数字类型转换）
APP_RATE_LIMIT_WINDOW=120
APP_RATE_LIMIT_MAX=200
